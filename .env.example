# Copy this file to .env and fill in your values

# =============================================================================
# Local LLM (Ollama)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# =============================================================================
# API Settings (for mobile app backend)
# =============================================================================
# REQUIRED: Secret key for JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-secret-key-here-generate-with-openssl

# Optional: Database URL (defaults to SQLite)
# DATABASE_URL=sqlite:///./api_users.db

# Optional: For PostgreSQL in production
# DATABASE_URL=postgresql://user:password@localhost:5432/drrag

# LLM provider
USE_OPENROUTER=true
OPENAI_API_KEY=
OPENROUTER_API_KEY=<your-openrouter-key>
OPENROUTER_API_KEYS=<your-openrouter-key>,<backup-key-1>,<backup-key-2>
OPENROUTER_KEY_ROTATION_SEED=0  # optional: fixes rotation order for testing
OPENROUTER_MODEL=google/gemini-2.5-flash

# =============================================================================
# Payment provider (Razorpay)
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_TOKENINFO_URL=https://oauth2.googleapis.com/tokeninfo

# Payment provider
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=rzp_test_your_secret
# Optional secret for webhook validation
PAYMENT_WEBHOOK_SECRET=replace-with-secret
# Optional UPI ID to show in responses
PAYMENT_UPI_VPA=clinique@okaxis

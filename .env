# ── LLM Provider ─────────────────────────────────────────────────────────────
# OpenRouter (free tier available)
# Get your key at: https://openrouter.ai/keys
USE_OPENROUTER=true
OPENROUTER_API_KEY=<key here>

# OpenAI (alternative — comment out OpenRouter lines above)
# OPENAI_API_KEY=

# ── Embeddings ───────────────────────────────────────────────────────────────
# false = free local HuggingFace embeddings (recommended)
USE_OPENAI_EMBEDDINGS=false

# ── Authentication ───────────────────────────────────────────────────────────
# REQUIRED — generate a strong random key, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# ── CORS (production) ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# CORS_ORIGINS=https://your-frontend.example.com

# ── Database ─────────────────────────────────────────────────────────────────
# DATABASE_URL=sqlite:///./api_users.db
